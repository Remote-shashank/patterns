def bullish_ul_v2(df, index=None, consumed_pivots=None, order=5):
   
    if consumed_pivots is None:
        consumed_pivots = set()

    if index is None:
        index = df.index[-1]

    df = df.loc[:index].copy()

    if len(df) < 50:
        return False

    df = _safe_swing_points(df, order=order)

    try:
        last_l1 = df[df.L1 == True].index[-1]

        last_l2 = df.loc[last_l1, 'L2']

        if pd.isna(last_l2) or last_l1 in consumed_pivots:
            return False

        if df.loc[last_l1:index].shape[0] <= 3:
            return False

        d = df.loc[last_l2:last_l1]

        up_fractals = d[d.Up_Fractal == True]
        if up_fractals.empty:
            return False

        highest_high = up_fractals.sort_values('High').High.iloc[-1]

        if _cuts(df, index, highest_high):
            consumed_pivots.add(last_l1)
            return True

    except (IndexError, TypeError):
        return False

    return False


def bearish_ul_v2(df, index=None, consumed_pivots=None, order=5):
   
    if consumed_pivots is None:
        consumed_pivots = set()

    if index is None:
        index = df.index[-1]

    df = df.loc[:index].copy()

    if len(df) < 50:
        return False

    df = _safe_swing_points(df, order=order)

    try:
        last_h1 = df[df.H1 == True].index[-1]

        last_h2 = df.loc[last_h1, 'H2']

        if pd.isna(last_h2) or last_h1 in consumed_pivots:
            return False

        if df.loc[last_h1:index].shape[0] <= 3:
            return False

        d = df.loc[last_h2:last_h1]

        down_fractals_in_range = d[d.Down_Fractal == True]
        if down_fractals_in_range.empty:
            return False

        # Most recent Down_Fractal up to index must still be the last one
        # in H2-H1 range — confirms no new Down_Fractal formed since H1
        if df[df.Down_Fractal == True].index[-1] != down_fractals_in_range.index[-1]:
            return False

        # Find lowest Down_Fractal low in H2-H1 range
        lowest_low = down_fractals_in_range.sort_values('Low').Low.iloc[0]

        if _cuts(df, index, lowest_low):
            consumed_pivots.add(last_h1)
            return True

    except (IndexError, TypeError):
        return False

    return False


def mat_hold(df):
    if len(df) < 21:
        return False

    first = df.iloc[-5]
    second = df.iloc[-4]
    third = df.iloc[-3]
    fourth = df.iloc[-2]
    last = df.iloc[-1]

    avg_range = (df["High"] - df["Low"]).rolling(21).mean().iloc[-1]

    strong_first = (
        first.Close > first.Open and
        abs(first.Close - first.Open) > 0.6 * (first.High - first.Low)
    )

    pullback_inside = (
        second.Close < first.High and second.Close > first.Low and
        third.Close < first.High and third.Close > first.Low and
        fourth.Close < first.High and fourth.Close > first.Low
    )

    small_pullback = (
        abs(second.Close - second.Open) < abs(first.Close - first.Open) and
        abs(third.Close - third.Open) < abs(first.Close - first.Open) and
        abs(fourth.Close - fourth.Open) < abs(first.Close - first.Open)
    )

    breakout = (
        last.Close > first.High and
        last.Close > last.Open and
        (last.High - last.Low) > avg_range
    )

    return strong_first and pullback_inside and small_pullback and breakout


def three_line_strike(df):
    """Three Line Strike (Bullish reversal)."""
    C3 = df["Close"].iloc[-4]
    O3 = df["Open"].iloc[-4]

    C2 = df["Close"].iloc[-3]
    O2 = df["Open"].iloc[-3]

    C1 = df["Close"].iloc[-2]
    O1 = df["Open"].iloc[-2]

    C = df["Close"].iloc[-1]
    Op = df["Open"].iloc[-1]

    return (
        C3 < O3 and C2 < O2 and C2 < C3 and C1 < O1 and C1 < C2 and Op < C1 and C > O3
    )


def side_by_side_white_lines(df):
  
    C2 = df["Close"].iloc[-3]
    O2 = df["Open"].iloc[-3]
    H2 = df["High"].iloc[-3]

    C1 = df["Close"].iloc[-2]
    O1 = df["Open"].iloc[-2]
    H1 = df["High"].iloc[-2]
    L1 = df["Low"].iloc[-2]

    C  = df["Close"].iloc[-1]
    Op = df["Open"].iloc[-1]
    H  = df["High"].iloc[-1]
    L  = df["Low"].iloc[-1]

    return (
        C2 > O2                         # Candle 1 is bullish
        and C1 > O1                     # Candle 2 is bullish
        and L1 > H2                     # Candle 2 gaps up above candle 1
        and C > Op                      # Candle 3 is bullish
        and L > H2                      # Candle 3 stays above candle 1 (gap not filled)
        and 0.95 < Op / O1 < 1.05      # Candles 2 & 3 open at similar price
                                        # — the core "side by side" definition
        and 0.9 < H1 / H < 1.1        # Candles 2 & 3 have similar highs
        and 0.9 < L1 / L < 1.1   


def z_consecutive_close_with_x_ema_bull(df, period=3, maPeriod=20):
    
    flag = False
    EMA = _safe_ema(df["Close"], maPeriod)
    for i in range(1, period + 1):
        if df["Close"].iloc[-i] > EMA.iloc[-i]:   # already correct
            flag = True
        else:
            flag = False
            break
    if flag:
        if (df["Close"].iloc[-period] > EMA.iloc[-period]) and (
            df["Close"].iloc[-period - 1] < EMA.iloc[-period - 1]
        ):
            return True
    return False


def close_crosses_above_closing_avg(df, period=20):
   
    try:
        close = df["Close"]
        if len(close) < period + 2:
            return False

        # Current confirmed bar (iloc[-1]) vs its rolling average
        curr_close = close.iloc[-1]
        curr_avg   = close.iloc[-period:].mean()

        # Previous bar (iloc[-2]) vs its rolling average
        prev_close = close.iloc[-2]
        prev_avg   = close.iloc[-period - 1:-1].mean()

        prev_below = prev_close < prev_avg
        curr_above = curr_close > curr_avg

        if prev_below and curr_above:
            return True

    except Exception:
        pass
    return False


