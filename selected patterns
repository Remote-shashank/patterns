def double_top(df, x=0.5, order=5):
    """Double Top pattern using confirmed pivots; emits on confirmation bar."""
    order = int(order)
    if order < 1:
        return False

    if len(df) < (2 * order) + 1:
        return False

    tolerance = x / 100

    highs = df["High"].values
    lows = df["Low"].values

    n_bars = len(df)
    signal = pd.Series(False, index=df.index)

    pivots = []

    for t in range(order, n_bars):
        i = t - order

        if i < order:
            continue

        if i + order >= n_bars:
            continue

        pivot_type = _confirm_pivot_2(highs, lows, i, order)

        if pivot_type is not None:
            pivots.append((i, pivot_type))

            if len(pivots) < 3:
                continue

            p1, p2, p3 = pivots[-3:]

            if p1[1] == "HIGH" and p2[1] == "LOW" and p3[1] == "HIGH":
                high1 = highs[p1[0]]
                valley = lows[p2[0]]
                high2 = highs[p3[0]]

                if not (high1 * (1 - tolerance) <= high2 <= high1 * (1 + tolerance)):
                    continue

                avg_peak = (high1 + high2) / 2

                if valley >= avg_peak * (1 - tolerance):
                    continue

                signal.iloc[t] = True

    return bool(signal.iloc[-1])


def bull_gap(df):
    """Bullish gap: previous high < current open and previous high < current low."""
    return df.High.iloc[-2] < df.Open.iloc[-1] and df.High.iloc[-2] < df.Low.iloc[-1]


