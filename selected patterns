def _safe_true_range(df):
    """Compute True Range without external dependency."""
    high = df["High"]
    low = df["Low"]
    close = df["Close"]
    tr1 = high - low
    tr2 = (high - close.shift(1)).abs()
    tr3 = (low - close.shift(1)).abs()
    return np.maximum(np.maximum(tr1, tr2), tr3)

def _safe_atr(df, period=20):
    """Compute ATR without external dependency."""
    high = df["High"]
    low = df["Low"]
    close = df["Close"]
    tr1 = high - low
    tr2 = (high - close.shift(1)).abs()
    tr3 = (low - close.shift(1)).abs()
    tr = np.maximum(np.maximum(tr1, tr2), tr3)
    return tr.rolling(window=period).mean()

def _safe_ema(series, period):
    """EMA using pandas ewm (replaces Packages.indicators.trend_indicators.ema)."""
    return series.ewm(span=period, adjust=False).mean()

def _confirm_pivot(price, i, order):
    window = price[i - order:i + order + 1]
    center = price[i]
    if center == window.max():
        return "HIGH"
    if center == window.min():
        return "LOW"
    return None

def _confirm_pivot_2(highs, lows, i, order):
    window_high = highs[i - order:i + order + 1]
    window_low = lows[i - order:i + order + 1]

    if highs[i] == window_high.max():
        return "HIGH"
    if lows[i] == window_low.min():
        return "LOW"
    return None

    
def _safe_fractals(df, order=5):
  
    up   = pd.Series(0, index=df.index)
    down = pd.Series(0, index=df.index)

    up_idx   = argrelextrema(df["High"].values, np.greater, order=order)[0]
    down_idx = argrelextrema(df["Low"].values,  np.less,    order=order)[0]

    up.iloc[up_idx]     = 1
    down.iloc[down_idx] = 1
    return up, down

    
def _safe_swing_points(df, order=5):
   
    up_fractal, down_fractal = _safe_fractals(df, order=order)
    df = df.copy()
    df['Up_Fractal']   = up_fractal
    df['Down_Fractal'] = down_fractal
    df['L1'] = False
    df['L2'] = pd.Series([None] * len(df), index=df.index, dtype='object')
    df['H1'] = False
    df['H2'] = pd.Series([None] * len(df), index=df.index, dtype='object')

    df_down = df[df.Down_Fractal == 1]
    df_up   = df[df.Up_Fractal == 1]

    # FIX 1: range(1, ...) — was range(2, ...), first L1 opportunity was always skipped
    for i in range(1, len(df_down)):
        if df_down.iloc[i].Low < df_down.iloc[i - 1].Low:
            df.loc[df_down.iloc[i].name, 'L1'] = True
            df.loc[df_down.iloc[i].name, 'L2'] = df_down.iloc[i - 1].name

    # FIX 2: range(1, ...) — was range(2, ...), first H1 opportunity was always skipped
    for i in range(1, len(df_up)):
        if df_up.iloc[i].High > df_up.iloc[i - 1].High:
            df.loc[df_up.iloc[i].name, 'H1'] = True
            df.loc[df_up.iloc[i].name, 'H2'] = df_up.iloc[i - 1].name

    return df


def _cuts(df, index, level):

    try:
        idx_pos = df.index.get_loc(index)
        if idx_pos < 1:
            return False

        # Direct cut: wick range straddles the level
        if df["High"].iloc[idx_pos] > level and df["Low"].iloc[idx_pos] < level:
            return True

        # Bear gap: level is in the gap below previous low, above current high
        elif (
            bear_gap(df.iloc[: idx_pos + 1])
            and level < df["Low"].iloc[idx_pos - 1]
            and level > df["High"].iloc[idx_pos]
        ):
            return True

        # Bull gap: level is in the gap above previous high, below current low
        elif (
            bull_gap(df.iloc[: idx_pos + 1])
            and level > df["High"].iloc[idx_pos - 1]
            and level < df["Low"].iloc[idx_pos]
        ):
            return True

        return False

    # FIX: specific exceptions only — bare except Exception hid real bugs
    except (KeyError, IndexError, TypeError):
        return False

def inside_day(df, period=20, x=0.6):
    """Inside day with volatility compression."""
    if "ATR" in df.columns and "TR" in df.columns:
        ATR = df.ATR
        TR = df.TR
    else:
        TR = _safe_true_range(df)
        ATR = _safe_atr(df, period)
    if (
        df["High"].iloc[-1] < df["High"].iloc[-2]
        and df["Low"].iloc[-1] > df["Low"].iloc[-2]
        and TR.iloc[-1] < (x * ATR.iloc[-1])
    ):
        return True
    else:
        return False


def _is_wide_ranging_day_bearish(df):
    """Check if latest bar is a bearish wide ranging day."""
    if "ATR" in df.columns and "TR" in df.columns:
        ATR = df.ATR
        TR = df.TR
    else:
        TR = _safe_true_range(df)
        ATR = _safe_atr(df, 20)
    if (TR.iloc[-1] >= ATR.iloc[-1]) and 10 * np.abs(df["Open"].iloc[-1] - df["Close"].iloc[-1]) >= 5 * (
        df["High"].iloc[-1] - df["Low"].iloc[-1]
    ):
        if df["Open"].iloc[-1] > df["Close"].iloc[-1]:
            return True
    return False


