HARMONIC_PATTERNS = {
    "bullish_crab": {
        "direction": (1, -1, 1, -1),
        "ratios": {
            "AB": (0.382, 0.618),
            "BC": (0.382, 0.886),
            "CD": (2.24, 3.618),
        },
    },
}

def _validate_harmonic(X, A, B, C, D, config, err):
    XA, AB, BC, CD = A - X, B - A, C - B, D - C
    direction = config["direction"]

    if not (
        np.sign(XA) == direction[0]
        and np.sign(AB) == direction[1]
        and np.sign(BC) == direction[2]
        and np.sign(CD) == direction[3]
    ):
        return False

    ratios = config["ratios"]

    def in_range(value, base, low, high):
        return (low - err) * abs(base) <= abs(value) <= (high + err) * abs(base)

    if not in_range(AB, XA, *ratios["AB"]):
        return False

    if not in_range(BC, AB, *ratios["BC"]):
        return False

    if not in_range(CD, BC, *ratios["CD"]):
        return False

    return True


def harmonic_engine(df, pattern_name, order=5, err=0.10):
    if pattern_name not in HARMONIC_PATTERNS:
        raise ValueError(f"Unknown pattern: {pattern_name}")

    order = int(order)
    if order < 1:
        raise ValueError("order must be >= 1")

    config = HARMONIC_PATTERNS[pattern_name]

    price = df["Close"].values
    n_bars = len(price)

    signal = pd.Series(False, index=df.index)
    pivots = []

    for t in range(2 * order, n_bars):
        i = t - order

        window = price[i - order:i + order + 1]
        center = price[i]

        is_unique_high = center == window.max() and (window == center).sum() == 1
        is_unique_low = center == window.min() and (window == center).sum() == 1

        if is_unique_high or is_unique_low:
            pivots.append(i)

            if len(pivots) >= 5:
                last5 = pivots[-5:]
                X, A, B, C, D = price[last5]

                if _validate_harmonic(X, A, B, C, D, config, err):
                    signal.iloc[t] = True

    return signal
    

def _harmonic_pattern_signal(df, pattern_name, order=5, err=0.10):
    if len(df) < (2 * order) + 1:
        return False
    signal = harmonic_engine(df, pattern_name, order=order, err=err)
    return bool(signal.iloc[-1])


def _get_series(df, column_candidates):
    for col in column_candidates:
        if col in df.columns:
            series = df[col]
            if not series.isna().all():
                return series
    return None


def _compute_rsi_from_series(series, period=20):
    delta = series.diff()
    gain = delta.clip(lower=0)
    loss = -delta.clip(upper=0)
    avg_gain = gain.ewm(alpha=1 / period, adjust=False, min_periods=period).mean()
    avg_loss = loss.ewm(alpha=1 / period, adjust=False, min_periods=period).mean()
    rs = avg_gain / avg_loss.replace(0, np.nan)
    return 100 - (100 / (1 + rs))


def _compute_trix(df, period=20):
    close = df["Close"].astype(float)
    ema1 = close.ewm(span=period, adjust=False).mean()
    ema2 = ema1.ewm(span=period, adjust=False).mean()
    ema3 = ema2.ewm(span=period, adjust=False).mean()
    return ema3.pct_change(fill_method=None) * 100


def _compute_cci(df, period=20):
    typical_price = (df["High"] + df["Low"] + df["Close"]) / 3
    sma = typical_price.rolling(period).mean()
    mad = typical_price.rolling(period).apply(
        lambda x: np.mean(np.abs(x - np.mean(x))), raw=True
    )
    return (typical_price - sma) / (0.015 * mad.replace(0, np.nan))


def _compute_williams_r(df, period=20):
    highest_high = df["High"].rolling(period).max()
    lowest_low = df["Low"].rolling(period).min()
    denominator = (highest_high - lowest_low).replace(0, np.nan)
    return -100 * ((highest_high - df["Close"]) / denominator)


def _compute_ultimate_oscillator(df, short=5, medium=10, long=20):
    prev_close = df["Close"].shift(1)
    buying_pressure = df["Close"] - np.minimum(df["Low"], prev_close)
    true_range = np.maximum(df["High"], prev_close) - np.minimum(df["Low"], prev_close)
    true_range = true_range.replace(0, np.nan)

    avg_short = buying_pressure.rolling(short).sum() / true_range.rolling(short).sum()
    avg_medium = buying_pressure.rolling(medium).sum() / true_range.rolling(medium).sum()
    avg_long = buying_pressure.rolling(long).sum() / true_range.rolling(long).sum()

    return 100 * ((4 * avg_short) + (2 * avg_medium) + avg_long) / 7


def _compute_mfi(df, period=20):
    typical_price = (df["High"] + df["Low"] + df["Close"]) / 3
    money_flow = typical_price * df["Volume"]
    direction = typical_price.diff()

    positive_flow = money_flow.where(direction > 0, 0.0)
    negative_flow = money_flow.where(direction < 0, 0.0).abs()

    pos_sum = positive_flow.rolling(period).sum()
    neg_sum = negative_flow.rolling(period).sum().replace(0, np.nan)

    money_ratio = pos_sum / neg_sum
    return 100 - (100 / (1 + money_ratio))


def _compute_awesome_oscillator(df, short=5, long=34):
    median_price = (df["High"] + df["Low"]) / 2
    return median_price.rolling(short).mean() - median_price.rolling(long).mean()


def _compute_acceleration_oscillator(df):
    ao = _compute_awesome_oscillator(df)
    ao_sma5 = ao.rolling(5).mean()
    return ao - ao_sma5


def _compute_connors_rsi(df, rsi_period=3, streak_period=2, rank_period=100):
    close = df["Close"].astype(float)

    price_rsi = _compute_rsi_from_series(close, period=rsi_period)

    delta = close.diff()
    streak = pd.Series(0.0, index=df.index)
    for i in range(1, len(df)):
        if pd.isna(delta.iloc[i]) or delta.iloc[i] == 0:
            streak.iloc[i] = 0
        elif delta.iloc[i] > 0:
            streak.iloc[i] = streak.iloc[i - 1] + 1 if streak.iloc[i - 1] > 0 else 1
        else:
            streak.iloc[i] = streak.iloc[i - 1] - 1 if streak.iloc[i - 1] < 0 else -1

    streak_rsi = _compute_rsi_from_series(streak, period=streak_period)

    close_change = close.diff()
    percent_rank = close_change.rolling(rank_period).apply(
        lambda x: pd.Series(x).rank(pct=True).iloc[-1] * 100, raw=False
    )

    return (price_rsi + streak_rsi + percent_rank) / 3

def _momentum_indicator_series(df, indicator_name):
    if indicator_name == "TRIX":
        return _compute_trix(df)
    if indicator_name == "STOCHASTIC":
        return _safe_stochastic(df, period=20, smooth=3)
    if indicator_name == "RSI":
        return _compute_rsi_from_series(df["Close"], period=20)
    if indicator_name == "CRSI":
        return _compute_connors_rsi(df)
    if indicator_name == "CCI":
        return _compute_cci(df, period=20)
    if indicator_name == "WILLIAMS_R":
        return _compute_williams_r(df, period=20)
    if indicator_name == "ULTIMATE_OSCILLATOR":
        return _compute_ultimate_oscillator(df)
    if indicator_name == "MFI":
        if "Volume" not in df.columns:
            return None
        return _compute_mfi(df, period=14)
    if indicator_name == "AWESOME_OSCILLATOR":
        return _compute_awesome_oscillator(df)
    if indicator_name == "ACCELERATION_OSCILLATOR":
        return _compute_acceleration_oscillator(df)
    return None


def _momentum_indicator_series_from_candidates(df, candidates):
    normalized = {c.upper() for c in candidates}

    if "TRIX" in normalized:
        return _momentum_indicator_series(df, "TRIX")
    if {"STOCHASTIC", "STOCH", "%K"}.intersection(normalized):
        return _momentum_indicator_series(df, "STOCHASTIC")
    if "RSI" in normalized:
        return _momentum_indicator_series(df, "RSI")
    if {"CRSI", "CONNORS_RSI"}.intersection(normalized):
        return _momentum_indicator_series(df, "CRSI")
    if "CCI" in normalized:
        return _momentum_indicator_series(df, "CCI")
    if {"WILLIAMS_R", "WILLR", "WPR"}.intersection(normalized):
        return _momentum_indicator_series(df, "WILLIAMS_R")
    if {"ULTIMATE_OSCILLATOR", "ULTOSC", "UO"}.intersection(normalized):
        return _momentum_indicator_series(df, "ULTIMATE_OSCILLATOR")
    if "MFI" in normalized:
        return _momentum_indicator_series(df, "MFI")
    if {"AO", "AWESOME_OSCILLATOR"}.intersection(normalized):
        return _momentum_indicator_series(df, "AWESOME_OSCILLATOR")
    if {"AC", "ACCELERATION_OSCILLATOR"}.intersection(normalized):
        return _momentum_indicator_series(df, "ACCELERATION_OSCILLATOR")
    return None


INDICATOR_DELTA_THRESHOLD = 1e-6


def _find_fractals_bool(df, n=5):
    highs = df["High"]
    lows = df["Low"]

    fractal_highs = pd.Series(False, index=df.index)
    fractal_lows = pd.Series(False, index=df.index)

    for i in range(n, len(df) - n):
        window_highs = highs.iloc[i - n:i + n + 1]
        window_lows = lows.iloc[i - n:i + n + 1]

        center_high = highs.iloc[i]
        center_low = lows.iloc[i]

        if (
            center_high == window_highs.max()
            and (window_highs == center_high).sum() == 1
        ):
            fractal_highs.iloc[i + n] = True

        if (
            center_low == window_lows.min()
            and (window_lows == center_low).sum() == 1
        ):
            fractal_lows.iloc[i + n] = True

    return fractal_highs, fractal_lows


def _latest_confirmed_pivot_pair(fractal_flags, n=5):
    confirmed_positions = np.flatnonzero(fractal_flags.to_numpy())
    if confirmed_positions.size < 2:
        return None

    conf_pos_1 = int(confirmed_positions[-2])
    conf_pos_2 = int(confirmed_positions[-1])

    pivot_pos_1 = conf_pos_1 - n
    pivot_pos_2 = conf_pos_2 - n

    if pivot_pos_1 < 0 or pivot_pos_2 < 0:
        return None

    return pivot_pos_1, pivot_pos_2, conf_pos_1, conf_pos_2


def _regular_bullish_divergence(
    df,
    indicator_series,
    n=5,
):
    fractal_highs, fractal_lows = _find_fractals_bool(df, n=n)
    pivot_pair = _latest_confirmed_pivot_pair(fractal_lows, n=n)
    if pivot_pair is None:
        return False

    low_pos_1, low_pos_2, _, conf_pos_2 = pivot_pair
    if conf_pos_2 != len(df) - 1:
        return False

    price_low_1 = df["Low"].iloc[low_pos_1]
    price_low_2 = df["Low"].iloc[low_pos_2]

    ind_low_1 = indicator_series.iloc[low_pos_1]
    ind_low_2 = indicator_series.iloc[low_pos_2]

    if pd.isna(ind_low_1) or pd.isna(ind_low_2):
        return False

    indicator_delta = ind_low_2 - ind_low_1

    return price_low_2 < price_low_1 and indicator_delta > INDICATOR_DELTA_THRESHOLD


