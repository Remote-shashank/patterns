def spike_low(DF, n=5, k=2):
    """Spike Low pattern."""
    L1 = DF["Low"].iloc[-2]
    LL = DF["Low"].rolling(n).min().iloc[-3]
    L = DF["Low"].iloc[-1]
    atr_val = _safe_atr(DF, n).iloc[-3]

    return (LL - L1 > 1 * atr_val) and (L - L1 > k * atr_val)
    

def three_white_soldiers(df):
    """Three White Soldiers pattern."""
    C2 = df["Close"].iloc[-3]
    O2 = df["Open"].iloc[-3]
    H2 = df["High"].iloc[-3]
    L2 = df["Low"].iloc[-3]

    C1 = df["Close"].iloc[-2]
    O1 = df["Open"].iloc[-2]
    H1 = df["High"].iloc[-2]
    L1 = df["Low"].iloc[-2]

    C = df["Close"].iloc[-1]
    Op = df["Open"].iloc[-1]
    H = df["High"].iloc[-1]
    L = df["Low"].iloc[-1]

    return (
        C > C1
        and C1 > C2
        and C > Op
        and C1 > O1
        and C2 > O2
        and 2 * np.abs(C2 - O2) > H2 - L2
        and 2 * np.abs(C1 - O1) > H1 - L1
        and 2 * np.abs(C - Op) > H - L
        and Op > O1
        and Op < C1
        and O1 > O2
        and O1 < C2
    )

def morning_star1(df):
