def _indicator_divergence(df, candidates, mode="regular_bullish", n=5):
    indicator_series = _get_series(df, candidates)
    if indicator_series is None:
        indicator_series = _momentum_indicator_series_from_candidates(df, candidates)

    n = int(n)
    if n < 1:
        n = 1

    min_len = (2 * n) + 5
    if indicator_series is None or len(df) < min_len:
        return False

    if mode == "regular_bullish":
        return _regular_bullish_divergence(df, indicator_series, n=n)
    if mode == "regular_bearish":
        return _regular_bearish_divergence(df, indicator_series, n=n)
    if mode == "hidden_bullish":
        return _hidden_bullish_divergence(df, indicator_series, n=n)
    if mode == "hidden_bearish":
        return _hidden_bearish_divergence(df, indicator_series, n=n)
    return False

def _compute_volume_oscillator(df, short_period=10, long_period=20):
    volume = df["Volume"].astype(float)
    short_ema = volume.ewm(span=short_period, adjust=False).mean()
    long_ema = volume.ewm(span=long_period, adjust=False).mean()
    denominator = long_ema.replace(0, np.nan)
    return ((short_ema - long_ema) / denominator) * 100


def _compute_stochastic_volume(df, period=20):
    volume = df["Volume"].astype(float)
    low_min = volume.rolling(period).min()
    high_max = volume.rolling(period).max()
    denominator = (high_max - low_min).replace(0, np.nan)
    return 100 * (volume - low_min) / denominator


def _volume_indicator_series(df, name):
    if name == "VOLUME_OSCILLATOR":
        return _get_series(df, ["VOLUME_OSCILLATOR", "VO", "VOLUME_OSC"])
    if name == "STOCHASTIC_VOLUME":
        return _get_series(df, ["STOCHASTIC_VOLUME", "STOCH_VOLUME"])
    return None

