    Morning Star variant 1 — bullish reversal.
    Bar 2 size constrained by body-to-body comparison vs Bar 1.
    """
    C2 = df["Close"].iloc[-3]
    O2 = df["Open"].iloc[-3]
    H2 = df["High"].iloc[-3]
    L2 = df["Low"].iloc[-3]
    C1 = df["Close"].iloc[-2]
    O1 = df["Open"].iloc[-2]
    H1 = df["High"].iloc[-2]
    L1 = df["Low"].iloc[-2]
    C  = df["Close"].iloc[-1]
    Op = df["Open"].iloc[-1]

    bar1_body     = np.abs(O2 - C2)
    bar1_range    = H2 - L2
    bar2_body     = np.abs(O1 - C1)
    bar2_range    = H1 - L1
    bar1_midpoint = (O2 + C2) / 2
    lower_shadow  = min(O1, C1) - L1

    return (
        # Bar 1: strong bearish candle
        O2 > C2
        and 5 * bar1_body > 3 * bar1_range           # body > 60% of its range

        # Bar 2: small star, gaps down, lower shadow dominant
        and C2 > O1                                   # gap down
        and 2 * bar2_body < bar1_body                 # body < 50% of Bar 1's body
        and bar2_range > 2 * bar2_body                # wicks dominate body
        and lower_shadow > 0.3 * bar2_range           # FIX: lower shadow > 30% of range (robust to doji)

        # Bar 3: bullish, opens above Bar 2 body, confirms reversal
        and C > Op                                    # bullish
        and Op > max(O1, C1)                          # opens above Bar 2's body top (cleaner than two conditions)
        and C > bar1_midpoint                         # closes above 50% of Bar 1's body
    )


