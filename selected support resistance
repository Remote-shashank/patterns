from __future__ import annotations

from dataclasses import dataclass, field
from typing import Dict, List, Optional, Tuple

import numpy as np
import pandas as pd
from sklearn.cluster import DBSCAN


# ─────────────────────────────────────────────────────────────────────────────
# Data container
# ─────────────────────────────────────────────────────────────────────────────

@dataclass
class SRZone:
    """A single active support/resistance zone."""
    zone_high:          float
    zone_low:           float
    pivot_count:        int
    intersection_count: int  = field(default=0,    repr=False)
    price_was_inside:   bool = field(default=False, repr=False)
    # intersection_count: cumulative count of ENTRIES into the zone
    #   (outside->inside transitions only). Never resets.
    #   Zone invalidated when intersection_count >= invalidation_n.
    #
    # price_was_inside: whether price was inside the zone on the
    #   previous bar. Initialised False so the very first entry
    #   (even if price is already inside at zone birth) counts as
    #   visit 1. Each re-entry after a departure = one more visit.


# ─────────────────────────────────────────────────────────────────────────────
# Indicator
# ─────────────────────────────────────────────────────────────────────────────

class SupportResistanceIndicator:
    """
    Live / streaming Geometric Support & Resistance Indicator.

    Parameters
    ----------
    fractal_period : int
        Bars each side to confirm a pivot high/low (default 2).
    pivot_window : int
        Rolling bar window for pivot history fed into DBSCAN (default 252).
    atr_period : int
        ATR lookback period for epsilon computation (default 14).
    atr_window : int
        Bars over which mean ATR is averaged for epsilon (default 252).
    min_samples : int
        DBSCAN min_samples - minimum pivots to form a core point (default 3).
    jaccard_threshold : float
        Overlap threshold for zone replacement on rerun (default 0.65).
    variation : int
        1 -> pure [High, Low] clustering
        2 -> [High, Low] + swapped duplicate trick

    Usage
    -----
    >>> sr = SupportResistanceIndicator(fractal_period=5, variation=1)
    >>> for i in range(1, len(df) + 1):
    ...     result = sr.update(df.iloc[:i])

    Or backtest convenience:
    >>> results = sr.run_backtest(df)
    """

    def __init__(
        self,
        fractal_period:    int   = 2,
        pivot_window:      int   = 252,
        atr_period:        int   = 14,
        atr_window:        int   = 252,
        min_samples:       int   = 3,
        jaccard_threshold: float = 0.65,
        invalidation_n:    int   = 3,
        variation:         int   = 1,
    ) -> None:
        if variation not in (1, 2):
            raise ValueError("variation must be 1 or 2")
        self.fractal_period    = fractal_period
        self.pivot_window      = pivot_window
        self.atr_period        = atr_period
        self.atr_window        = atr_window
        self.min_samples       = min_samples
        self.jaccard_threshold = jaccard_threshold
        self.invalidation_n    = invalidation_n
        self.variation         = variation
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # State
    # ─────────────────────────────────────────────────────────────────────────

    def _init_state(self) -> None:
        self._pivot_highs:        List[Tuple] = []    # (timestamp, High, Low)
        self._pivot_lows:         List[Tuple] = []
        self._active_zones:       List[SRZone] = []
        self._last_confirmed_idx: int = -1

    def reset(self) -> None:
        """Clear all state. Call between symbols in a backtest."""
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # Indicator helpers
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _true_range(df: pd.DataFrame) -> pd.Series:
        pc = df["Close"].shift(1)
        return pd.concat(
            [df["High"] - df["Low"],
             (df["High"] - pc).abs(),
             (df["Low"]  - pc).abs()],
            axis=1,
        ).max(axis=1)

    def _atr_series(self, df: pd.DataFrame) -> pd.Series:
        return self._true_range(df).ewm(
            alpha=1.0 / self.atr_period, adjust=False
        ).mean()

    def _mean_atr(self, df: pd.DataFrame) -> float:
        """Mean ATR over the last atr_window bars — DBSCAN epsilon."""
        return float(self._atr_series(df).iloc[-self.atr_window:].mean())

    # ─────────────────────────────────────────────────────────────────────────
    # Fractal / pivot detection
    # ─────────────────────────────────────────────────────────────────────────

    def _is_pivot_high(self, df: pd.DataFrame, idx: int) -> bool:
        n = self.fractal_period
        if idx < n or idx + n >= len(df):
            return False
        centre = df["High"].iloc[idx]
        window = df["High"].iloc[idx - n: idx + n + 1]
        return bool(centre == window.max() and (window == centre).sum() == 1)

    def _is_pivot_low(self, df: pd.DataFrame, idx: int) -> bool:
        n = self.fractal_period
        if idx < n or idx + n >= len(df):
            return False
        centre = df["Low"].iloc[idx]
        window = df["Low"].iloc[idx - n: idx + n + 1]
        return bool(centre == window.min() and (window == centre).sum() == 1)

    # ─────────────────────────────────────────────────────────────────────────
    # Fix 3 — Softened _maxima / _minima structural filter
    #
    # _maxima: keep pivot high[i] if High[i] > mean(High[i-1], High[i+1])
    #          i.e. above the average of its two neighbours.
    #          Edge pivots (first, last) always kept unconditionally.
    #
    # _minima: keep pivot low[i]  if Low[i]  < mean(Low[i-1],  Low[i+1])
    #          Edge pivots always kept unconditionally.
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _maxima(pivots: List[Tuple]) -> List[Tuple]:
        """Softened structural filter — keep dominant swing highs."""
        if len(pivots) < 3:
            return pivots
        result = [pivots[0]]                                  # edge — always keep
        for i in range(1, len(pivots) - 1):
            curr_h         = pivots[i][1]
            neighbour_mean = (pivots[i - 1][1] + pivots[i + 1][1]) / 2.0
            if curr_h > neighbour_mean:
                result.append(pivots[i])
        result.append(pivots[-1])                             # edge — always keep
        return result

    @staticmethod
    def _minima(pivots: List[Tuple]) -> List[Tuple]:
        """Softened structural filter — keep dominant swing lows."""
        if len(pivots) < 3:
            return pivots
        result = [pivots[0]]                                  # edge — always keep
        for i in range(1, len(pivots) - 1):
            curr_l         = pivots[i][2]
            neighbour_mean = (pivots[i - 1][2] + pivots[i + 1][2]) / 2.0
            if curr_l < neighbour_mean:
                result.append(pivots[i])
        result.append(pivots[-1])                             # edge — always keep
        return result

    # ─────────────────────────────────────────────────────────────────────────
    # Fix 1 — Jaccard overlap helper
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _jaccard(zh_a: float, zl_a: float, zh_b: float, zl_b: float) -> float:
        """
        Jaccard overlap between two 1-D price zones [zl_a, zh_a] and [zl_b, zh_b].
            Jaccard = Intersection / Union
        Returns 0.0 if zones do not overlap at all.
        """
        intersection = max(0.0, min(zh_a, zh_b) - max(zl_a, zl_b))
        union        = max(zh_a, zh_b) - min(zl_a, zl_b)
        if union <= 0.0:
            return 0.0
        return intersection / union

    # ─────────────────────────────────────────────────────────────────────────
    # DBSCAN clustering — produces fresh zone list
    # ─────────────────────────────────────────────────────────────────────────

    def _compute_zones(
        self, pivots: List[Tuple], epsilon: float
    ) -> List[SRZone]:
        """
        Run DBSCAN on pivot [High, Low] features.
        Returns a list of SRZone with breach_count = 0.
        Variation 2 appends swapped copy before fitting but computes
        centroids from original points only.
        """
        if len(pivots) < self.min_samples:
            return []

        original = np.array([[p[1], p[2]] for p in pivots])  # [High, Low]

        if self.variation == 2:
            swapped  = original[:, ::-1].copy()               # [Low, High]
            fit_data = np.vstack([original, swapped])
        else:
            fit_data = original

        db = DBSCAN(eps=epsilon, min_samples=self.min_samples)
        db.fit(fit_data)

        labels = db.labels_[:len(pivots)]                     # original points only

        zones = []
        for label in set(labels):
            if label == -1:
                continue                                       # noise — always discard
            mask        = labels == label
            cluster_pts = original[mask]
            zone_high   = float(cluster_pts[:, 0].max())     # highest High tested
            zone_low    = float(cluster_pts[:, 1].min())     # lowest Low tested
            pivot_count = int(mask.sum())
            if zone_high < zone_low:                          # safety swap
                zone_high, zone_low = zone_low, zone_high
            zones.append(SRZone(zone_high, zone_low, pivot_count))

        zones.sort(key=lambda z: z.pivot_count, reverse=True)
        return zones

    # ─────────────────────────────────────────────────────────────────────────
    # Fix 1 — Merge new zones into active list
    # ─────────────────────────────────────────────────────────────────────────

    def _merge_zones(self, new_zones: List[SRZone]) -> None:
        """
        Merge a fresh DBSCAN zone list into the active zone list.

        For each new zone:
          - Find the active zone with the highest Jaccard overlap.
          - If best Jaccard >= jaccard_threshold:
              REPLACE that active zone (update boundaries + pivot_count,
              preserve breach_count so the counter is not reset).
          - If best Jaccard < jaccard_threshold:
              ADD as a brand new zone (breach_count = 0).

        Active zones not matched by any new zone are LEFT UNTOUCHED.
        They persist in the active list until price invalidates them.
        """
        active = list(self._active_zones)

        for nz in new_zones:
            best_idx     = -1
            best_jaccard = 0.0

            for i, az in enumerate(active):
                j = self._jaccard(
                    nz.zone_high, nz.zone_low,
                    az.zone_high, az.zone_low,
                )
                if j > best_jaccard:
                    best_jaccard = j
                    best_idx     = i

            if best_jaccard >= self.jaccard_threshold and best_idx >= 0:
                # Update in place — preserve intersection_count and price_was_inside
                active[best_idx].zone_high          = nz.zone_high
                active[best_idx].zone_low           = nz.zone_low
                active[best_idx].pivot_count        = nz.pivot_count
                # intersection_count and price_was_inside intentionally kept
            else:
                # Genuinely new zone — add to active list
                active.append(nz)

        active.sort(key=lambda z: z.pivot_count, reverse=True)
        self._active_zones = active

    # ─────────────────────────────────────────────────────────────────────────
    # Invalidation — intersection-based (n cumulative bars)
    # ─────────────────────────────────────────────────────────────────────────

    def _update_intersection_counts(self, cur: pd.Series) -> None:
        """
        Count genuine ENTRIES into the zone — outside->inside transitions.

        For each active zone on each bar:
          1. Determine if the current bar physically intersects the zone:
                 bar_low <= zone_high  AND  bar_high >= zone_low
          2. A count increments ONLY on an outside->inside transition:
                 price_was_inside == False  AND  currently intersects
             Continuous residence inside the zone (was_inside=True and
             still intersecting) does NOT increment the count.
          3. Update price_was_inside for the next bar.
          4. Remove the zone when intersection_count >= invalidation_n.

        Philosophy:
            Each count = one genuine return visit after a prior departure.
            A zone where price sits continuously accumulates at most 1
            count (the initial entry). Only real departure-and-return
            cycles consume the zone's significance.
        """
        bar_high  = float(cur["High"])
        bar_low   = float(cur["Low"])
        surviving = []

        for z in self._active_zones:
            currently_inside = (bar_low <= z.zone_high) and (bar_high >= z.zone_low)

            # Only count on outside -> inside transition
            if currently_inside and not z.price_was_inside:
                z.intersection_count += 1

            # Update state for next bar
            z.price_was_inside = currently_inside

            if z.intersection_count < self.invalidation_n:
                surviving.append(z)
            # intersection_count >= invalidation_n -> zone mitigated

        self._active_zones = surviving

    # ─────────────────────────────────────────────────────────────────────────
    # Core update — call once per bar close
    # ─────────────────────────────────────────────────────────────────────────

    def update(self, df: pd.DataFrame) -> Dict:
        """
        Process a single new bar.

        Parameters
        ----------
        df : pd.DataFrame
            Full OHLCV dataframe up to and including the current bar.
            Required columns: Open, High, Low, Close, Volume.

        Returns
        -------
        dict
            {
                "zones": [
                    {"zone_high": float, "zone_low": float, "pivot_count": int},
                    ...
                ]
            }
            Sorted by pivot_count descending. Empty list if no active zones.
        """
        n        = self.fractal_period
        min_bars = n * 2 + 1 + self.atr_period
        if len(df) < min_bars:
            return {"zones": []}

        cur = df.iloc[-1]

        # ── Step 1: Fractal confirmation at position [current - n] ────────────
        confirm_idx = len(df) - 1 - n

        if confirm_idx != self._last_confirmed_idx:
            self._last_confirmed_idx = confirm_idx
            confirmed_ts  = df.index[confirm_idx]
            confirmed_row = df.iloc[confirm_idx]
            new_pivot     = False

            if self._is_pivot_high(df, confirm_idx):
                self._pivot_highs.append((
                    confirmed_ts,
                    float(confirmed_row["High"]),
                    float(confirmed_row["Low"]),
                ))
                new_pivot = True

            if self._is_pivot_low(df, confirm_idx):
                self._pivot_lows.append((
                    confirmed_ts,
                    float(confirmed_row["High"]),
                    float(confirmed_row["Low"]),
                ))
                new_pivot = True

            # ── Step 2: DBSCAN rerun + merge (Fix 1) ─────────────────────────
            if new_pivot:
                cutoff = (
                    df.index[-self.pivot_window]
                    if len(df) >= self.pivot_window
                    else df.index[0]
                )
                self._pivot_highs = [p for p in self._pivot_highs if p[0] >= cutoff]
                self._pivot_lows  = [p for p in self._pivot_lows  if p[0] >= cutoff]

                # Fix 3 — softened structural filter
                filtered_highs = self._maxima(self._pivot_highs)
                filtered_lows  = self._minima(self._pivot_lows)
                all_pivots     = filtered_highs + filtered_lows

                if len(all_pivots) >= self.min_samples:
                    epsilon   = self._mean_atr(df)
                    new_zones = self._compute_zones(all_pivots, epsilon)
                    # Fix 1 — merge new zones into active list
                    self._merge_zones(new_zones)

        # ── Step 3: Intersection count + invalidation every bar ──────────────
        self._update_intersection_counts(cur)

        return {
            "zones": [
                {
                    "zone_high":   round(z.zone_high,   4),
                    "zone_low":    round(z.zone_low,    4),
                    "pivot_count": z.pivot_count,
                }
                for z in self._active_zones
            ]
        }

    # ─────────────────────────────────────────────────────────────────────────
    # Backtest convenience wrapper
    # ─────────────────────────────────────────────────────────────────────────

    def run_backtest(self, df: pd.DataFrame) -> List[Dict]:
        """
        Run the indicator bar-by-bar over a complete historical dataset,
        exactly replicating live bar-by-bar behaviour.

        Returns
        -------
        list of dicts, one per bar:
            {
                "timestamp": <bar index label>,
                "zones":     [...],
            }
        """
        self.reset()
        results = []
        for i in range(1, len(df) + 1):
            snapshot = self.update(df.iloc[:i])
            results.append({"timestamp": df.index[i - 1], **snapshot})
        return results


