# ─────────────────────────────────────────────────────────────────────────────
# Data container
# ─────────────────────────────────────────────────────────────────────────────

@dataclass
class OrderBlock:
    """A single identified order block."""
    ob_timestamp: Any    # index label of the OB candle
    ob_price: float      # High (bearish OB) or Low (bullish OB) of the OB candle
    direction: str       # 'bullish' | 'bearish'


# ─────────────────────────────────────────────────────────────────────────────
# Indicator
# ─────────────────────────────────────────────────────────────────────────────

class OrderBlockIndicator:
    """
    Live/streaming Order Block Indicator.

    Parameters
    ----------
    fractal_period : int
        Bars each side required to confirm a pivot high/low (default 2).
        A fractal is confirmed only after `fractal_period` bars have
        closed after the candidate candle.
    atr_period : int
        Wilder's smoothed ATR lookback period (default 14).
    variation : int
        1 → simple backtrace (V1)
        2 → structural backtrace with V1 fallback (V2)

    Usage
    -----
    >>> ob = OrderBlockIndicator(fractal_period=2, atr_period=14, variation=1)
    >>> for i in range(1, len(df) + 1):
    ...     result = ob.update(df.iloc[:i])
    ...     # result["bullish_obs"]  — list of active bullish OBs
    ...     # result["bearish_obs"]  — list of active bearish OBs

    Or use the convenience wrapper:
    >>> results = ob.run_backtest(df)
    """

    def __init__(
        self,
        fractal_period: int = 2,
        atr_period: int = 14,
        variation: int = 1,
    ) -> None:
        if variation not in (1, 2):
            raise ValueError("variation must be 1 or 2")
        self.fractal_period = fractal_period
        self.atr_period = atr_period
        self.variation = variation
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # State management
    # ─────────────────────────────────────────────────────────────────────────

    def _init_state(self) -> None:
        # Bearish pipeline — UP breakout → red-candle OB
        self._pivot_high_ts: Optional[Any] = None   # latest confirmed pivot high
        self._brkout_high_ts: Optional[Any] = None  # breakout candle timestamp
        self._wait_atr_high: bool = False            # waiting for after-breakout bar

        # Bullish pipeline — DOWN breakout → green-candle OB
        self._pivot_low_ts: Optional[Any] = None
        self._brkout_low_ts: Optional[Any] = None
        self._wait_atr_low: bool = False

        # Active OB lists — fully decoupled from pipeline state
        self._bearish_obs: List[OrderBlock] = []
        self._bullish_obs: List[OrderBlock] = []

    def reset(self) -> None:
        """Clear all state.  Call between symbols when running a backtest."""
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # Indicator calculations
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _true_range(df: pd.DataFrame) -> pd.Series:
        pc = df["Close"].shift(1)
        return pd.concat(
            [
                df["High"] - df["Low"],
                (df["High"] - pc).abs(),
                (df["Low"]  - pc).abs(),
            ],
            axis=1,
        ).max(axis=1)

    def _atr_series(self, df: pd.DataFrame) -> pd.Series:
        """Wilder's smoothed ATR  (EWM, alpha = 1 / period)."""
        return self._true_range(df).ewm(
            alpha=1.0 / self.atr_period, adjust=False
        ).mean()

    # ─────────────────────────────────────────────────────────────────────────
    # Fractal / pivot detection
    # ─────────────────────────────────────────────────────────────────────────

    def _is_pivot_high(self, df: pd.DataFrame, idx: int) -> bool:
        """
        True if candle at integer position `idx` is a strict pivot high:
        its High is the unique maximum in the window
        [idx - fractal_period  …  idx + fractal_period].
        """
        n = self.fractal_period
        if idx < n or idx + n >= len(df):
            return False
        centre = df["High"].iloc[idx]
        window = df["High"].iloc[idx - n: idx + n + 1]
        return bool(centre == window.max() and (window == centre).sum() == 1)

    def _is_pivot_low(self, df: pd.DataFrame, idx: int) -> bool:
        n = self.fractal_period
        if idx < n or idx + n >= len(df):
            return False
        centre = df["Low"].iloc[idx]
        window = df["Low"].iloc[idx - n: idx + n + 1]
        return bool(centre == window.min() and (window == centre).sum() == 1)

    # ─────────────────────────────────────────────────────────────────────────
    # ATR breakout filter
    # ─────────────────────────────────────────────────────────────────────────

    def _passes_atr_filter(self, df: pd.DataFrame, brkout_ts: Any) -> bool:
        """
        Returns True if ANY of the 3-candle window
        [candle before breakout | breakout candle | candle after breakout]
        has TR > ATR.

        Called on the bar that has just closed AFTER the breakout candle,
        so all three candles are available in `df`.
        """
        try:
            idx = df.index.get_loc(brkout_ts)
        except KeyError:
            return False
        if idx < 1 or idx + 1 >= len(df):
            return False
        window = df.iloc[idx - 1: idx + 2]
        return bool((window["TR"] > window["ATR"]).any())

    # ─────────────────────────────────────────────────────────────────────────
    # Backtrace helpers
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _between(
        df: pd.DataFrame, ts_start: Any, ts_end: Any
    ) -> pd.DataFrame:
        """Candles strictly between ts_start and ts_end (both exclusive)."""
        return df.loc[ts_start:ts_end].iloc[1:-1]

    def _backtrace_v1(
        self,
        df: pd.DataFrame,
        fractal_ts: Any,
        brkout_ts: Any,
        direction: str,
    ) -> Tuple[Optional[Any], Optional[float]]:
        """
        Variation 1 — Simple Backtrace
        ================================
        Walk backwards from breakout candle toward fractal.
        First opposite-colour candle encountered = OB.

          UP   breakout → look for first RED   candle → OB price = candle High
          DOWN breakout → look for first GREEN candle → OB price = candle Low
        """
        region = self._between(df, fractal_ts, brkout_ts)
        if region.empty:
            return None, None

        for ts, row in region.iloc[::-1].iterrows():
            if direction == "up"   and row["Open"] > row["Close"]:
                return ts, float(row["High"])
            if direction == "down" and row["Open"] < row["Close"]:
                return ts, float(row["Low"])

        return None, None

    def _backtrace_v2(
        self,
        df: pd.DataFrame,
        fractal_ts: Any,
        brkout_ts: Any,
        direction: str,
    ) -> Tuple[Optional[Any], Optional[float]]:
        """
        Variation 2 — Structural Backtrace
        =====================================
        1. Find the single extreme candle in (fractal, breakout):
               UP   move → candle with the lowest  Low
               DOWN move → candle with the highest High
        2. Walk forward from that extreme (inclusive) toward the breakout.
           First opposite-colour candle = OB.
        3. If no qualifying candle is found, fall back to V1.
        """
        region = self._between(df, fractal_ts, brkout_ts)
        if region.empty:
            return self._backtrace_v1(df, fractal_ts, brkout_ts, direction)

        # ── Locate extreme ────────────────────────────────────────────────────
        extreme_ts = (
            region["Low"].idxmin()
            if direction == "up"
            else region["High"].idxmax()
        )

        # ── Forward scan from extreme (inclusive) ────────────────────────────
        for ts, row in region.loc[extreme_ts:].iterrows():
            if direction == "up"   and row["Open"] > row["Close"]:
                return ts, float(row["High"])
            if direction == "down" and row["Open"] < row["Close"]:
                return ts, float(row["Low"])

        # ── Fallback to V1 ────────────────────────────────────────────────────
        return self._backtrace_v1(df, fractal_ts, brkout_ts, direction)

    def _run_backtrace(
        self,
        df: pd.DataFrame,
        fractal_ts: Any,
        brkout_ts: Any,
        direction: str,
    ) -> Tuple[Optional[Any], Optional[float]]:
        """Dispatch to the selected variation."""
        if self.variation == 2:
            return self._backtrace_v2(df, fractal_ts, brkout_ts, direction)
        return self._backtrace_v1(df, fractal_ts, brkout_ts, direction)

    # ─────────────────────────────────────────────────────────────────────────
    # OB invalidation
    # ─────────────────────────────────────────────────────────────────────────

    def _invalidate_obs(self, cur: pd.Series, cur_atr: float) -> None:
        """
        Remove any active OB whose price zone has been touched by the
        current bar's wick.

        Bearish OB at P (High of red candle — sits below the fractal high):
            After the UP breakout, price may retrace downward toward P.
            Invalidated when  Low  ≤  P + ATR
            (wick entered the zone [P − ATR, P + ATR] from above)

        Bullish OB at P (Low of green candle — sits above the fractal low):
            After the DOWN breakout, price may retrace upward toward P.
            Invalidated when  High  ≥  P − ATR
            (wick entered the zone [P − ATR, P + ATR] from below)
        """
        low  = float(cur["Low"])
        high = float(cur["High"])

        self._bearish_obs = [
            ob for ob in self._bearish_obs
            if low > ob.ob_price + cur_atr
        ]
        self._bullish_obs = [
            ob for ob in self._bullish_obs
            if high < ob.ob_price - cur_atr
        ]

    # ─────────────────────────────────────────────────────────────────────────
    # Core update — call once per bar close
    # ─────────────────────────────────────────────────────────────────────────

    def update(self, df: pd.DataFrame) -> Dict[str, List[Dict]]:
        """
        Process a single new bar.

        Parameters
        ----------
        df : pd.DataFrame
            Full OHLCV dataframe up to and including the current bar.
            Required columns: Open, High, Low, Close.
            Index must be ordered (e.g. DatetimeIndex or RangeIndex).

        Returns
        -------
        dict
            {
                "bullish_obs": [{"ob_timestamp": …, "ob_price": …}, …],
                "bearish_obs": [{"ob_timestamp": …, "ob_price": …}, …],
            }
            An empty list means no active OBs in that direction.
        """
        n = self.fractal_period
        # Need enough bars to: confirm a fractal (n each side) + ATR warmup
        if len(df) < n * 2 + 1 + self.atr_period:
            return {"bullish_obs": [], "bearish_obs": []}

        # ── Attach TR / ATR to a working copy ─────────────────────────────────
        df = df.copy()
        df["TR"]  = self._true_range(df)
        df["ATR"] = self._atr_series(df)

        current_ts = df.index[-1]
        cur        = df.iloc[-1]
        cur_atr    = float(cur["ATR"])

        # ─────────────────────────────────────────────────────────────────────
        # STEP 1 — Fractal confirmation
        #
        # The candle exactly `n` positions before the latest has now had
        # `n` bars close after it, so we can confirm whether it is a pivot.
        #
        # Invariant (guaranteed by fractal_period ≥ 2 + 1-bar ATR wait):
        #   a same-direction fractal can NEVER form while _wait_atr_* is True,
        #   so the `confirmed_ts != self._pivot_*_ts` guard is sufficient.
        # ─────────────────────────────────────────────────────────────────────
        confirm_idx  = len(df) - 1 - n
        confirmed_ts = df.index[confirm_idx]

        if self._is_pivot_high(df, confirm_idx):
            if confirmed_ts != self._pivot_high_ts:
                # New (more recent) fractal high — replace and reset pipeline
                self._pivot_high_ts  = confirmed_ts
                self._brkout_high_ts = None
                self._wait_atr_high  = False

        if self._is_pivot_low(df, confirm_idx):
            if confirmed_ts != self._pivot_low_ts:
                self._pivot_low_ts  = confirmed_ts
                self._brkout_low_ts = None
                self._wait_atr_low  = False

        # ─────────────────────────────────────────────────────────────────────
        # STEP 2 — Bearish pipeline  (UP breakout → red-candle OB)
        # ─────────────────────────────────────────────────────────────────────
        if self._pivot_high_ts is not None:
            pivot_high_price = float(df.loc[self._pivot_high_ts, "High"])

            if self._wait_atr_high:
                # ── Current bar is the candle AFTER the breakout ──────────────
                # Run the ATR filter over the 3-candle window now that it is
                # fully closed.
                if self._passes_atr_filter(df, self._brkout_high_ts):
                    ob_ts, ob_price = self._run_backtrace(
                        df,
                        self._pivot_high_ts,
                        self._brkout_high_ts,
                        "up",
                    )
                    if ob_ts is not None:
                        self._bearish_obs.append(
                            OrderBlock(ob_ts, ob_price, "bearish")
                        )

                # Fractal is now consumed (wick already crossed it).
                # Reset the full pipeline — wait for the next fresh fractal.
                self._pivot_high_ts  = None
                self._brkout_high_ts = None
                self._wait_atr_high  = False

            else:
                # ── Watch for any wick crossing above the fractal high ────────
                if float(cur["High"]) > pivot_high_price:
                    self._brkout_high_ts = current_ts
                    self._wait_atr_high  = True

        # ─────────────────────────────────────────────────────────────────────
        # STEP 3 — Bullish pipeline  (DOWN breakout → green-candle OB)
        # ─────────────────────────────────────────────────────────────────────
        if self._pivot_low_ts is not None:
            pivot_low_price = float(df.loc[self._pivot_low_ts, "Low"])

            if self._wait_atr_low:
                if self._passes_atr_filter(df, self._brkout_low_ts):
                    ob_ts, ob_price = self._run_backtrace(
                        df,
                        self._pivot_low_ts,
                        self._brkout_low_ts,
                        "down",
                    )
                    if ob_ts is not None:
                        self._bullish_obs.append(
                            OrderBlock(ob_ts, ob_price, "bullish")
                        )

                self._pivot_low_ts  = None
                self._brkout_low_ts = None
                self._wait_atr_low  = False

            else:
                if float(cur["Low"]) < pivot_low_price:
                    self._brkout_low_ts = current_ts
                    self._wait_atr_low  = True

        # ─────────────────────────────────────────────────────────────────────
        # STEP 4 — Invalidate OBs that have been touched this bar
        # ─────────────────────────────────────────────────────────────────────
        self._invalidate_obs(cur, cur_atr)

        # ─────────────────────────────────────────────────────────────────────
        # Return snapshot of all currently active OBs
        # ─────────────────────────────────────────────────────────────────────
        return {
            "bullish_obs": [
                {"ob_timestamp": ob.ob_timestamp, "ob_price": ob.ob_price}
                for ob in self._bullish_obs
            ],
            "bearish_obs": [
                {"ob_timestamp": ob.ob_timestamp, "ob_price": ob.ob_price}
                for ob in self._bearish_obs
            ],
        }

    # ─────────────────────────────────────────────────────────────────────────
    # Backtest convenience wrapper
    # ─────────────────────────────────────────────────────────────────────────

    def run_backtest(self, df: pd.DataFrame) -> List[Dict]:
        """
        Run the indicator bar-by-bar over a complete historical dataset,
        exactly replicating live bar-by-bar behaviour.

        Parameters
        ----------
        df : pd.DataFrame
            Full OHLCV dataframe (Open, High, Low, Close).

        Returns
        -------
        list of dicts, one per bar:
            {
                "timestamp"  : <bar index label>,
                "bullish_obs": [...],
                "bearish_obs": [...],
            }
        """
        self.reset()
        results = []
        for i in range(1, len(df) + 1):
            snapshot = self.update(df.iloc[:i])
            results.append({"timestamp": df.index[i - 1], **snapshot})
        return results


