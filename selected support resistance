# ─────────────────────────────────────────────────────────────────────────────
# Data containers
# ─────────────────────────────────────────────────────────────────────────────

@dataclass
class HVNZone:
    """A single active HVN zone."""
    zone_high:          float
    zone_low:           float
    zone_volume:        float
    intersection_count: int  = field(default=0,     repr=False)
    price_was_inside:   bool = field(default=False,  repr=False)
    in_profile:         bool = field(default=True,   repr=False)
    # in_profile: True if this zone was matched by the most recent
    # DBSCAN/profile rerun. Used to track Condition 2 invalidation.


# ─────────────────────────────────────────────────────────────────────────────
# Indicator
# ─────────────────────────────────────────────────────────────────────────────

class HVNIndicator:
    """
    Live / streaming High Volume Node Support & Resistance Indicator.

    Parameters
    ----------
    window : int
        Rolling bar window for volume profile construction (default 252).
    atr_period : int
        ATR lookback period; bucket_size = ATR × atr_factor (default 14).
    atr_factor : float
        Multiplier for ATR to set bucket size (default 0.5).
    k : float
        HVN threshold: bucket qualifies if volume > mean + k × std (default 1.0).
    jaccard_threshold : float
        Overlap threshold for zone replacement on profile rerun (default 0.65).
    invalidation_n : int
        Number of entry visits before a zone is considered mitigated (default 3).

    Usage
    -----
    >>> hvn = HVNIndicator()
    >>> for i in range(1, len(df) + 1):
    ...     result = hvn.update(df.iloc[:i])

    Or backtest convenience:
    >>> results = hvn.run_backtest(df)
    """

    def __init__(
        self,
        window:            int   = 252,
        atr_period:        int   = 14,
        atr_factor:        float = 0.5,
        k:                 float = 1.0,
        jaccard_threshold: float = 0.65,
        invalidation_n:    int   = 3,
        proximity_n:       float = 5.0,
    ) -> None:
        self.window            = window
        self.atr_period        = atr_period
        self.atr_factor        = atr_factor
        self.k                 = k
        self.jaccard_threshold = jaccard_threshold
        self.invalidation_n    = invalidation_n
        self.proximity_n       = proximity_n
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # State
    # ─────────────────────────────────────────────────────────────────────────

    def _init_state(self) -> None:
        self._active_zones: List[HVNZone] = []

    def reset(self) -> None:
        """Clear all state. Call between symbols in a backtest."""
        self._init_state()

    # ─────────────────────────────────────────────────────────────────────────
    # ATR helper
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _true_range(df: pd.DataFrame) -> pd.Series:
        pc = df["Close"].shift(1)
        return pd.concat(
            [df["High"] - df["Low"],
             (df["High"] - pc).abs(),
             (df["Low"]  - pc).abs()],
            axis=1,
        ).max(axis=1)

    def _atr(self, df: pd.DataFrame) -> float:
        """Current ATR value (EMA-based)."""
        tr = self._true_range(df)
        atr_series = tr.ewm(alpha=1.0 / self.atr_period, adjust=False).mean()
        return float(atr_series.iloc[-1])

    # ─────────────────────────────────────────────────────────────────────────
    # Jaccard overlap
    # ─────────────────────────────────────────────────────────────────────────

    @staticmethod
    def _jaccard(zh_a: float, zl_a: float, zh_b: float, zl_b: float) -> float:
        """Jaccard overlap between two 1-D price zones."""
        intersection = max(0.0, min(zh_a, zh_b) - max(zl_a, zl_b))
        union        = max(zh_a, zh_b) - min(zl_a, zl_b)
        return intersection / union if union > 0.0 else 0.0

    # ─────────────────────────────────────────────────────────────────────────
    # Volume profile construction
    # ─────────────────────────────────────────────────────────────────────────

    def _build_profile(
        self, window_df: pd.DataFrame, bucket_size: float
    ) -> Tuple[np.ndarray, np.ndarray]:
        """
        Build a volume profile over window_df.

        Returns
        -------
        bucket_lows : np.ndarray
            Lower boundary of each bucket.
        bucket_vols : np.ndarray
            Total volume accumulated in each bucket.
        """
        # Floor-aligned grid
        min_low   = float(window_df["Low"].min())
        max_high  = float(window_df["High"].max())
        grid_start = math.floor(min_low  / bucket_size) * bucket_size
        grid_end   = math.ceil(max_high  / bucket_size) * bucket_size

        n_buckets  = max(1, round((grid_end - grid_start) / bucket_size))
        bucket_lows = np.array(
            [grid_start + i * bucket_size for i in range(n_buckets)]
        )
        bucket_vols = np.zeros(n_buckets)

        for _, row in window_df.iterrows():
            bar_high   = float(row["High"])
            bar_low    = float(row["Low"])
            bar_vol    = float(row["Volume"])
            bar_range  = bar_high - bar_low

            if bar_range <= 0:
                # Doji — assign full volume to bucket containing Close
                close = float(row["Close"])
                idx   = int((close - grid_start) / bucket_size)
                idx   = max(0, min(n_buckets - 1, idx))
                bucket_vols[idx] += bar_vol
                continue

            # Distribute volume uniformly across overlapping buckets
            for i, bl in enumerate(bucket_lows):
                bt = bl + bucket_size          # bucket top
                overlap = max(0.0, min(bar_high, bt) - max(bar_low, bl))
                if overlap > 0:
                    bucket_vols[i] += bar_vol * (overlap / bar_range)

        return bucket_lows, bucket_vols

    # ─────────────────────────────────────────────────────────────────────────
    # HVN identification and zone merging
    # ─────────────────────────────────────────────────────────────────────────

    def _identify_hvn_zones(
        self, bucket_lows: np.ndarray, bucket_vols: np.ndarray,
        bucket_size: float
    ) -> List[HVNZone]:
        """
        Identify HVN buckets and merge adjacent ones into zones.

        HVN threshold: bucket_volume > mean + k × std

        Merge rule: adjacent HVN buckets merge into one zone.
        A non-HVN bucket breaks the chain — A and C never merge
        across a non-HVN B.
        """
        if len(bucket_vols) == 0:
            return []

        mean_vol = float(np.mean(bucket_vols))
        std_vol  = float(np.std(bucket_vols))
        threshold = mean_vol + self.k * std_vol

        is_hvn = bucket_vols > threshold

        zones        = []
        in_zone      = False
        zone_low     = 0.0
        zone_vol_acc = 0.0

        for i, (bl, bv) in enumerate(zip(bucket_lows, bucket_vols)):
            bt = bl + bucket_size
            if is_hvn[i]:
                if not in_zone:
                    # Start a new zone
                    zone_low     = bl
                    zone_vol_acc = 0.0
                    in_zone      = True
                zone_vol_acc += bv
                zone_high_current = bt
            else:
                if in_zone:
                    # Close the current zone
                    zones.append(HVNZone(
                        zone_high   = zone_high_current,
                        zone_low    = zone_low,
                        zone_volume = zone_vol_acc,
                    ))
                    in_zone = False

        # Close final zone if still open
        if in_zone:
            zones.append(HVNZone(
                zone_high   = zone_high_current,
                zone_low    = zone_low,
                zone_volume = zone_vol_acc,
            ))

        zones.sort(key=lambda z: z.zone_volume, reverse=True)
        return zones

    # ─────────────────────────────────────────────────────────────────────────
    # Merge new zones into active list (Jaccard-based persistence)
    # ─────────────────────────────────────────────────────────────────────────

    def _merge_zones(self, new_zones: List[HVNZone]) -> None:
        """
        Merge fresh profile zones into the active zone list.

        For each new zone:
            Best Jaccard ≥ threshold → replace existing zone
                (update boundaries + volume, preserve counters)
            Best Jaccard < threshold → add as new zone

        Active zones not matched by any new zone:
            → mark in_profile = False (triggers Condition 2 check)
        """
        active = list(self._active_zones)

        # Reset in_profile flag — will be set True for matched zones
        for az in active:
            az.in_profile = False

        for nz in new_zones:
            best_j, best_idx = 0.0, -1
            for i, az in enumerate(active):
                j = self._jaccard(nz.zone_high, nz.zone_low,
                                  az.zone_high, az.zone_low)
                if j > best_j:
                    best_j, best_idx = j, i

            if best_j >= self.jaccard_threshold and best_idx >= 0:
                # Update in place — preserve intersection_count + price_was_inside
                active[best_idx].zone_high   = nz.zone_high
                active[best_idx].zone_low    = nz.zone_low
                active[best_idx].zone_volume = nz.zone_volume
                active[best_idx].in_profile  = True
            else:
                # Genuinely new zone
                nz.in_profile = True
                active.append(nz)

        active.sort(key=lambda z: z.zone_volume, reverse=True)
        self._active_zones = active

    # ─────────────────────────────────────────────────────────────────────────
    # Intersection count update (entry-based)
    # ─────────────────────────────────────────────────────────────────────────

    def _update_intersection_counts(self, cur: pd.Series) -> None:
        """
        Count genuine entries into each zone (outside → inside transitions).
        Update price_was_inside for next bar.
        """
        bar_high = float(cur["High"])
        bar_low  = float(cur["Low"])

        for z in self._active_zones:
            currently_inside = (bar_low <= z.zone_high) and (bar_high >= z.zone_low)
            if currently_inside and not z.price_was_inside:
                z.intersection_count += 1
            z.price_was_inside = currently_inside

    # ─────────────────────────────────────────────────────────────────────────
    # Invalidation
    # ─────────────────────────────────────────────────────────────────────────

    def _invalidate_zones(self) -> None:
        """
        Remove zones that meet either invalidation condition.

        Condition 1 — Price mitigation:
            intersection_count >= invalidation_n → remove always

        Condition 2 — Volume fade + prior engagement:
            not in_profile AND intersection_count > 0 → remove

        Never-remove rule:
            not in_profile AND intersection_count == 0 → KEEP
            (unvisited HVN — strongest level, institutional
             positions untouched)
        """
        surviving = []
        for z in self._active_zones:
            # Condition 1 — fully mitigated by price
            if z.intersection_count >= self.invalidation_n:
                continue
            # Condition 2 — volume faded AND price has visited
            if not z.in_profile and z.intersection_count > 0:
                continue
            surviving.append(z)
        self._active_zones = surviving

    # ─────────────────────────────────────────────────────────────────────────
    # Proximity filter — output layer only
    # ─────────────────────────────────────────────────────────────────────────

    def _proximity_filter(
        self, zones: List[HVNZone], close: float, atr: float
    ) -> List[HVNZone]:
        """
        Filter active zones to only those within proximity_n × ATR
        of the current close price.

        Distance calculation:
            Price inside zone  → distance = 0  (always included)
            Price above zone   → distance = close - zone_high
            Price below zone   → distance = zone_low - close

        Zones outside the proximity band are kept internally —
        they will reappear in output if price moves toward them.
        """
        max_distance = self.proximity_n * atr
        result = []
        for z in zones:
            if close >= z.zone_low and close <= z.zone_high:
                distance = 0.0
            elif close > z.zone_high:
                distance = close - z.zone_high
            else:
                distance = z.zone_low - close

            if distance <= max_distance:
                result.append(z)
        return result

    def _consolidate_output(
        self, zones: List[HVNZone], bucket_size: float
    ) -> List[dict]:
        """
        Consolidate overlapping or near-adjacent visible zones into clean
        output zones before returning to the caller.

        Two zones are merged when:
            zone_B_low <= zone_A_high + bucket_size
            i.e. they overlap OR are separated by ≤ 1 bucket_size gap

        This collapses clusters that arise from bucket grid boundary
        artifacts — zones that are institutionally the same level but
        got split by the grid alignment.

        Merge result:
            zone_high   = max of the two zone_highs
            zone_low    = min of the two zone_lows
            zone_volume = sum (combined institutional interest)

        Returns plain dicts sorted by zone_volume descending.
        Internal HVNZone objects are NOT modified.
        """
        if not zones:
            return []

        # Sort by zone_low ascending for the sweep
        sorted_zones = sorted(zones, key=lambda z: z.zone_low)

        merged = []
        cur_low    = sorted_zones[0].zone_low
        cur_high   = sorted_zones[0].zone_high
        cur_volume = sorted_zones[0].zone_volume

        for z in sorted_zones[1:]:
            if z.zone_low <= cur_high + bucket_size:
                # Overlapping or within 1 bucket_size gap → extend
                cur_high   = max(cur_high, z.zone_high)
                cur_volume += z.zone_volume
            else:
                # Gap too large → close current, start new
                merged.append({
                    "zone_high":   round(cur_high,   4),
                    "zone_low":    round(cur_low,    4),
                    "zone_volume": round(cur_volume, 2),
                })
                cur_low    = z.zone_low
                cur_high   = z.zone_high
                cur_volume = z.zone_volume

        # Close final zone
        merged.append({
            "zone_high":   round(cur_high,   4),
            "zone_low":    round(cur_low,    4),
            "zone_volume": round(cur_volume, 2),
        })

        merged.sort(key=lambda z: z["zone_volume"], reverse=True)
        return merged

    def update(self, df: pd.DataFrame) -> Dict:
        """
        Process a single new bar.

        Parameters
        ----------
        df : pd.DataFrame
            Full OHLCV dataframe up to and including the current bar.
            Required columns: Open, High, Low, Close, Volume.

        Returns
        -------
        dict
            {
                "hvn_zones": [
                    {
                        "zone_high":   float,
                        "zone_low":    float,
                        "zone_volume": float,
                    },
                    ...
                ]
            }
            Sorted by zone_volume descending. Empty list if no active zones.
        """
        min_bars = max(self.window, self.atr_period + 1)
        if len(df) < min_bars:
            return {"hvn_zones": [], "all_active": []}

        cur       = df.iloc[-1]
        window_df = df.iloc[-self.window:]

        # ── Step 1: ATR → bucket size ─────────────────────────────────────
        bucket_size = self._atr(df) * self.atr_factor
        if bucket_size <= 0:
            return {"hvn_zones": [], "all_active": []}

        # ── Step 2: Build volume profile ──────────────────────────────────
        bucket_lows, bucket_vols = self._build_profile(window_df, bucket_size)

        # ── Step 3: Identify HVN zones ────────────────────────────────────
        new_zones = self._identify_hvn_zones(bucket_lows, bucket_vols, bucket_size)

        # ── Step 4: Merge into active list (Jaccard persistence) ──────────
        self._merge_zones(new_zones)

        # ── Step 5: Update intersection counts ───────────────────────────
        self._update_intersection_counts(cur)

        # ── Step 6: Invalidation ─────────────────────────────────────────
        self._invalidate_zones()

        # ── Step 7: Proximity filter — output only, internals unchanged ──
        close       = float(cur["Close"])
        current_atr = self._atr(df)
        visible     = self._proximity_filter(self._active_zones, close, current_atr)

        # ── Step 8: Consolidate nearby/overlapping visible zones ──────────
        return {
            "hvn_zones": self._consolidate_output(visible, bucket_size),
            "all_active": [
                {
                    "zone_high":          round(z.zone_high,   4),
                    "zone_low":           round(z.zone_low,    4),
                    "zone_volume":        round(z.zone_volume, 2),
                    "intersection_count": z.intersection_count,
                }
                for z in self._active_zones
            ],
        }

    # ─────────────────────────────────────────────────────────────────────────
    # Backtest convenience wrapper
    # ─────────────────────────────────────────────────────────────────────────

    def run_backtest(self, df: pd.DataFrame) -> List[Dict]:
        """
        Run the indicator bar-by-bar over a complete historical dataset,
        exactly replicating live bar-by-bar behaviour.

        Returns
        -------
        list of dicts, one per bar:
            {
                "timestamp": <bar index label>,
                "hvn_zones": [...],
            }
        """
        self.reset()
        results = []
        for i in range(1, len(df) + 1):
            snapshot = self.update(df.iloc[:i])
            results.append({"timestamp": df.index[i - 1], **snapshot})
        return results


